# Doxyfile for ConsoleForge v0.2.0
# Generated for Doxygen 1.16.x

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = "ConsoleForge"
PROJECT_NUMBER         = 0.2.0
PROJECT_BRIEF          = "Elm-architecture TUI framework for .NET 8"
PROJECT_LOGO           =
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = src/ConsoleForge \
                         src/ConsoleForge.SourceGen
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.cs
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */bin/* */obj/*

# Exclude terminal internals (Termios P/Invoke and Windows kernel details)
# that are implementation details, not API surface.
EXCLUDE                = src/ConsoleForge/Terminal/Termios.cs \
                         src/ConsoleForge/Terminal/WindowsConsole.cs \
                         src/ConsoleForge.SourceGen/EquatableArray.cs

#---------------------------------------------------------------------------
# Source parsing — C# XML doc via JAVADOC-style bridge
#---------------------------------------------------------------------------
OPTIMIZE_OUTPUT_JAVA   = YES
JAVADOC_AUTOBRIEF      = YES
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_ANON_NSPACES   = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
SHOW_INCLUDE_FILES     = NO
INLINE_SOURCES         = NO

#---------------------------------------------------------------------------
# Groups / namespaces
#---------------------------------------------------------------------------
# Map C# namespaces to Doxygen groups for cleaner navigation.
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = NO

#---------------------------------------------------------------------------
# HTML output
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
HTML_COLORSTYLE        = DARK
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 280
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_DYNAMIC_SECTIONS  = YES
SEARCHENGINE           = YES

# Extra CSS tweaks for readability (optional, add docs/custom.css if desired)
HTML_EXTRA_STYLESHEET  =

#---------------------------------------------------------------------------
# No LaTeX / RTF / man / XML
#---------------------------------------------------------------------------
GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO
GENERATE_DOCBOOK       = NO
GENERATE_AUTOGEN_DEF   = NO

#---------------------------------------------------------------------------
# Diagrams — disabled (no Graphviz dependency required)
#---------------------------------------------------------------------------
HAVE_DOT               = NO
COLLABORATION_GRAPH    = NO
INCLUDE_GRAPH          = NO
INCLUDED_BY_GRAPH      = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = NO
WARN_LOGFILE           = docs/doxygen-warnings.log

#---------------------------------------------------------------------------
# Namespace → module mapping (improves treeview grouping)
#---------------------------------------------------------------------------
# ConsoleForge.Core     — runtime loop, model, commands, components, keymaps
# ConsoleForge.Layout   — layout engine, render context, widget interfaces
# ConsoleForge.Styling  — styles, themes, colours, borders
# ConsoleForge.Terminal — terminal abstraction and platform implementations
# ConsoleForge.Widgets  — all built-in widget implementations
# ConsoleForge.SourceGen — Roslyn source generators and diagnostics

#---------------------------------------------------------------------------
# Misc
#---------------------------------------------------------------------------
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
CPP_CLI_SUPPORT        = YES
TAB_SIZE               = 4
MARKDOWN_SUPPORT       = YES
MARKDOWN_ID_STYLE      = DOXYGEN
TOC_INCLUDE_HEADINGS   = 3
TYPEDEF_HIDES_STRUCT   = NO
